    </joint>

    <joint name="elbowR">
      <state_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="effort" />
    </joint>
    
  </ros2_control>

  <gazebo>
    <plugin filename="odri_gz_ros2_control-system" name="odri_gz_ros2_control::GazeboOdriSimROS2ControlPlugin">
