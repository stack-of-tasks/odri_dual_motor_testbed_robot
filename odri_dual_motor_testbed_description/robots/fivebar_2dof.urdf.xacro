    </plugin>
  </gazebo>
  
  <!-- ================================================================ -->
  <!--      Gazebo Harmonic (gz-sim8) system plugin for five-bar loop closure. -->
  <!--      Exact direct geometric model: reads motorL/motorR and imposes -->
  <!--      elbowL/elbowR via Joint::ResetPosition every step. -->
  <!--      See five_bar_mgd_spec.md at the repository root. -->
  <!--      ================================================================ -->
  <gazebo>
    <plugin filename="libFiveBarClosurePlugin.so"
            name="odri_gz::FiveBarClosurePlugin">
      <!-- Actuated joints (inputs, theta1/theta2). -->
      <motor_joint1>motorL</motor_joint1>
      <motor_joint2>motorR</motor_joint2>
      <!-- Passive joints (outputs, beta1/beta2), imposed exactly. -->
      <elbow_joint1>elbowL</elbow_joint1>
      <elbow_joint2>elbowR</elbow_joint2>
      <!-- Geometry parameters (verified numerically, see
           five_bar_mgd_spec.md section 2). -->
      <a_x>-0.065</a_x>
      <a_z>0</a_z>
      <b_x>0.065</b_x>
      <b_z>0</b_z>
      <l1>0.06</l1>
      <l2>0.125</l2>
      <phi1>3.14159265358979323846</phi1>
      <phi2>1.9504681943696776</phi2>
      <psi1>1.1061036468685321</psi1>
      <psi2>2.6769066384729094</psi2>
    </plugin>
  </gazebo>

</robot>
